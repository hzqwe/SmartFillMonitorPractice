<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>FreeSql.Provider.SqliteCore</id>
    <version>3.5.305</version>
    <title>FreeSql.Provider.SqliteCore</title>
    <authors>FreeSql,ncc,YeXiangQin</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>logo.png</icon>
    <readme>readme.md</readme>
    <projectUrl>https://github.com/2881099/FreeSql</projectUrl>
    <description>FreeSql 数据库实现，基于 Microsoft.Data.Sqlite.Core、Sqlite 3.0，支持 .netstandard2.0 .net6.0 .net8.0 .net10.0</description>
    <tags>FreeSql ORM sqlite</tags>
    <repository type="git" url="https://github.com/2881099/FreeSql" branch="refs/heads/master" commit="8171fe51f1edf4d77d117ae0e7dbb91a5848b71b" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="FreeSql" version="3.5.305" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="6.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="FreeSql" version="3.5.305" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="FreeSql" version="3.5.305" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="10.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="FreeSql" version="3.5.305" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="10.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>