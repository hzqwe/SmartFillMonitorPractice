    <projectUrl>https://github.com/2881099/FreeSql</projectUrl>
    <description>FreeSql is the ORM in .NetCore, .NetFramework, And Xamarin. It supports Mysql, Postgresql, SqlServer, Oracle, Sqlite, Firebird, Clickhouse, DuckDB, TDengine, QuestDB, Odbc, Oledb, 达梦, 人大金仓, 南大通用, 虚谷, 神舟通用, 翰高, And Access</description>
    <tags>FreeSql ORM</tags>
    <repository type="git" url="https://github.com/2881099/FreeSql" branch="refs/heads/master" commit="8171fe51f1edf4d77d117ae0e7dbb91a5848b71b" />
    <dependencies>
      <group targetFramework=".NETFramework4.0" />
      <group targetFramework=".NETFramework4.5" />
      <group targetFramework=".NETFramework4.5.1" />
      <group targetFramework=".NETStandard2.0" />
      <group targetFramework=".NETStandard2.1" />
    </dependencies>
  </metadata>
