<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Serilog.Sinks.SQLite</id>
    <version>6.0.0</version>
    <authors>Saleem Mirza</authors>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <projectUrl>http://serilog.net/</projectUrl>
    <iconUrl>http://serilog.net/images/serilog-sink-nuget.png</iconUrl>
    <description>Serilog event sink that writes to SQLite database</description>
    <copyright>Copyright © Zethian Inc. 2020-2030</copyright>
    <tags>serilog logging SQLite</tags>
    <repository type="git" url="https://github.com/saleem-mirza/serilog-sinks-sqlite" />
    <dependencies>
      <group targetFramework="net7.0">
        <dependency id="Microsoft.CSharp" version="4.7.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="7.0.5" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.3" exclude="Build,Analyzers" />
        <dependency id="SQLite" version="3.13.0" exclude="Build,Analyzers" />
        <dependency id="Serilog" version="2.12.0" exclude="Build,Analyzers" />
        <dependency id="System.Data.SQLite.Core" version="1.0.115.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.CSharp" version="4.7.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Data.Sqlite.Core" version="7.0.5" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.3" exclude="Build,Analyzers" />
        <dependency id="SQLite" version="3.13.0" exclude="Build,Analyzers" />
        <dependency id="Serilog" version="2.12.0" exclude="Build,Analyzers" />
        <dependency id="System.Data.SQLite.Core" version="1.0.115.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>