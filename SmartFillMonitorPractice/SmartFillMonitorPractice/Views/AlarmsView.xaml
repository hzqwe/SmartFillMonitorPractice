<UserControl x:Class="SmartFillMonitorPractice.Views.AlarmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SmartFillMonitorPractice.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <TabControl Style="{StaticResource AppTabControlStyle}">
        <TabItem Header="活动报警" Style="{StaticResource AppTabItemStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前活动报警" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AppTextMain}"/>
                        <Border Background="{StaticResource AppDanger}" CornerRadius="10" Padding="8,4" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding ActiveAlarmCount}" FontSize="14" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="刷新" Command="{Binding RefreshCommand}" Width="90" Style="{StaticResource OutLineButton}"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActiveAlarms}" Margin="12,0,12,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Margin="0,0,0,10" Background="#2D1111" BorderBrush="{StaticResource AppBoderBrush}" BorderThickness="4,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock FontWeight="Bold" FontSize="15" Foreground="#FFCCCC">
                                                <Run Text="{Binding Code}"/>
                                                <Run Text=" : "/>
                                                <Run Text="{Binding Title}"/>
                                            </TextBlock>

                                            <TextBlock Text="{Binding Description}" Margin="0,6,0,0" Foreground="{StaticResource AppTextMuted}" FontSize="14" TextWrapping="Wrap"/>

                                            <WrapPanel Margin="0,10,0,0">
                                                <TextBlock Text="状态：" Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AppAccentColor}" FontSize="12" Margin="0,0,16,0"/>
                                                <TextBlock Text="来源：" Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding TriggeredByTypeText}" Foreground="{StaticResource AppTextMain}" FontSize="12"/>
                                                <TextBlock Text=" / " Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding TriggeredBy}" Foreground="{StaticResource AppTextMain}" FontSize="12"/>
                                            </WrapPanel>

                                            <WrapPanel Margin="0,6,0,0">
                                                <TextBlock Text="确认人：" Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding AckUser}" Foreground="{StaticResource AppTextMain}" FontSize="12" Margin="0,0,12,0"/>
                                                <TextBlock Text="确认时间：" Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                                <TextBlock Text="{Binding AckTimeStr}" Foreground="{StaticResource AppTextMain}" FontSize="12"/>
                                            </WrapPanel>

                                            <TextBlock Text="处理意见" Margin="0,10,0,4" Foreground="{StaticResource AppTextMuted}" FontSize="12"/>
                                            <Border Background="#1E1E1E" BorderBrush="{StaticResource AppBoderBrush}" BorderThickness="1" CornerRadius="4" Padding="2">
                                                <TextBox Text="{Binding ProcessSuggestion,UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         MinHeight="56"
                                                         TextWrapping="Wrap"
                                                         Padding="6"
                                                         Background="#1E1E1E"
                                                         Foreground="{StaticResource AppTextMain}"
                                                         CaretBrush="{StaticResource AppAccentColor}"
                                                         BorderBrush="{StaticResource AppAccentColor}"
                                                         BorderThickness="1"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TimeStr}" Foreground="#888888" FontSize="12" HorizontalAlignment="Right"/>
                                            <Button Content="{Binding AcknowledgeButtonText}"
                                                    Style="{StaticResource AppButtonStyle}"
                                                    Command="{Binding DataContext.AcknowledgeAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,8,0,0"
                                                    Background="#555555"
                                                    Width="96"
                                                    IsEnabled="{Binding CanAcknowledge}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ActiveAlarmCount,Converter={StaticResource ZeroToVisibilityConverter}}">
                    <TextBlock Text="✓" FontSize="48" Foreground="{StaticResource AppSuccess}" HorizontalAlignment="Center"/>
                    <TextBlock Text="当前无活动报警" FontSize="16" Foreground="{StaticResource AppTextMuted}" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="历史报警" Style="{StaticResource AppTabItemStyle}">
            <Grid Background="{StaticResource AppBgDark}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource AppBgPanel}"
                        BorderBrush="{StaticResource AppBoderBrush}"
                        BorderThickness="1"
                        Margin="12,12,12,8"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="开始时间" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding HistoryStartDate,UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="至" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding HistoryEndDate,UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="级别" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="100"
                                      ItemsSource="{Binding HistorySeverityOptions}"
                                      DisplayMemberPath="Value"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedHistorySeverity,UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="查询" Command="{Binding LoadHistoryAlarmsCommand}" Style="{StaticResource OutLineButton}" Width="80" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource AppBgPanel}"
                        BorderBrush="{StaticResource AppBoderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="12,0,12,12">
                    <DataGrid ItemsSource="{Binding HistoryAlarms}" IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="报警编码" Binding="{Binding Code}"/>
                            <DataGridTextColumn Header="报警标题" Binding="{Binding Title}"/>
                            <DataGridTextColumn Header="报警级别" Binding="{Binding SeverityText}"/>
                            <DataGridTextColumn Header="触发来源" Binding="{Binding TriggeredByTypeText}"/>
                            <DataGridTextColumn Header="触发人/来源" Binding="{Binding TriggeredBy}"/>
                            <DataGridTextColumn Header="报警描述" Binding="{Binding Description}"/>
                            <DataGridTextColumn Header="开始时间" Binding="{Binding TimeStr}"/>
                            <DataGridTextColumn Header="确认人" Binding="{Binding AckUser}"/>
                            <DataGridTextColumn Header="确认时间" Binding="{Binding AckTimeStr}"/>
                            <DataGridTextColumn Header="恢复人" Binding="{Binding RecoverUser}"/>
                            <DataGridTextColumn Header="恢复时间" Binding="{Binding RecoverTimeStr}"/>
                            <DataGridTextColumn Header="处理意见" Binding="{Binding ProcessSuggestion}"/>
                            <DataGridTextColumn Header="持续时间" Binding="{Binding DurationText}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid Grid.Row="2" Margin="12,0,12,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding HistoryPageText}" Foreground="{StaticResource AppTextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding HistoryTotalCount,StringFormat=共 {0} 条}" Foreground="{StaticResource AppTextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="上一页"
                                Command="{Binding PrevHistoryPageCommand}"
                                Style="{StaticResource OutLineButton}"
                                Width="80"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanPrevHistoryPage}"/>
                        <Button Content="下一页"
                                Command="{Binding NextHistoryPageCommand}"
                                Style="{StaticResource OutLineButton}"
                                Width="80"
                                IsEnabled="{Binding CanNextHistoryPage}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="测试报警" Style="{StaticResource AppTabItemStyle}">
            <Grid Background="{StaticResource AppBgDark}">
                <Border Style="{StaticResource CardStyle}" Margin="12" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="测试报警联调" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AppTextMain}" HorizontalAlignment="Center"/>
                        <TextBlock Text="触发后可在“活动报警”中完成确认和恢复，并检查责任链是否正确落库。"
                                   Margin="0,8,0,20"
                                   Foreground="{StaticResource AppTextMuted}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Button Content="触发测试报警"
                                Width="140"
                                Height="36"
                                Style="{StaticResource AppButtonStyle}"
                                Background="{StaticResource AppAccentColor}"
                                Command="{Binding TestAlarmCommand}"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
