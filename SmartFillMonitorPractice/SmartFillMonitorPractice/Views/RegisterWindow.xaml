<Window x:Class="SmartFillMonitorPractice.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SmartFill Monitor Practice - Register"
        Height="600"
        Width="820"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#0094F5"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#007ACC"/>
        <SolidColorBrush x:Key="DarkBg" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBg" Color="#252535"/>
        <SolidColorBrush x:Key="TextDim" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="InputBg" Color="#2F2F41"/>

        <Style TargetType="Button" x:Key="CloseBtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0,6,0,0">
                            <Path Data="M1,1 L9,9 M9,1 L1,9"
                                  Stroke="White"
                                  StrokeThickness="1.5"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="InputBorderStyle">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="Button" x:Key="MordenBtnStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource DarkBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#333">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10,0,0,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#004e92" Offset="0"/>
                        <GradientStop Color="#000428" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Path Data="M10,20 L20,5 L30,20 L40,5 L50,20 L50,40 L10,40 Z"
                          Fill="White"
                          Opacity="0.8"
                          Height="60"
                          Stretch="Uniform"/>
                    <TextBlock Text="SmartFill Monitor Practice"
                               FontSize="24"
                               Foreground="White"
                               Margin="0,20,0,5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="创建系统账户"
                               FontSize="14"
                               Foreground="#AACCEE"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="RoleHintTextBlock"
                               Text="首个用户可创建管理员，后续公开注册仅允许工程师。"
                               FontSize="13"
                               Foreground="#E8F5FF"
                               TextWrapping="Wrap"
                               Margin="0,26,0,0"
                               Width="240"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="{StaticResource CardBg}">
                <Button Style="{StaticResource CloseBtnStyle}"
                        Width="20"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="Cancel_Click"/>

                <StackPanel VerticalAlignment="Center" Margin="40,20">
                    <TextBlock Text="注册账户"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,20"/>

                    <TextBlock x:Name="HintTextBlock"
                               Text=""
                               FontSize="12"
                               Foreground="#77C6FF"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="用户类型" FontSize="14" Foreground="{StaticResource TextDim}" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <ComboBox x:Name="RoleComboBox"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="Black"
                                  FontSize="14"
                                  Padding="10,0"
                                  DisplayMemberPath="DisplayName"/>
                    </Border>

                    <TextBlock Text="用户名" FontSize="14" Foreground="{StaticResource TextDim}" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="UserNameTextBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Text="密码" FontSize="14" Foreground="{StaticResource TextDim}" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="14"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="White"
                                     GotKeyboardFocus="PasswordBox_FocusChanged"
                                     LostKeyboardFocus="PasswordBox_FocusChanged"
                                     PreviewKeyDown="PasswordBox_KeyChanged"
                                     PreviewKeyUp="PasswordBox_KeyChanged"/>
                    </Border>
                    <TextBlock x:Name="PasswordCapsLockHintTextBlock"
                               Text="大写锁定已打开"
                               FontSize="11"
                               Foreground="#FFD166"
                               Margin="0,-8,4,8"
                               HorizontalAlignment="Right"
                               Visibility="Collapsed"/>

                    <TextBlock Text="确认密码" FontSize="14" Foreground="{StaticResource TextDim}" Margin="0,0,0,5"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="14"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="White"
                                     GotKeyboardFocus="PasswordBox_FocusChanged"
                                     LostKeyboardFocus="PasswordBox_FocusChanged"
                                     PreviewKeyDown="PasswordBox_KeyChanged"
                                     PreviewKeyUp="PasswordBox_KeyChanged"/>
                    </Border>
                    <TextBlock x:Name="ConfirmPasswordCapsLockHintTextBlock"
                               Text="大写锁定已打开"
                               FontSize="11"
                               Foreground="#FFD166"
                               Margin="0,-8,4,8"
                               HorizontalAlignment="Right"
                               Visibility="Collapsed"/>

                    <TextBlock Text="密码至少 10 位，并包含大写字母、小写字母和数字。"
                               FontSize="12"
                               Foreground="{StaticResource TextDim}"
                               Margin="0,2,0,14"
                               TextWrapping="Wrap"/>

                    <Button Content="注册"
                            Style="{StaticResource MordenBtnStyle}"
                            Background="{StaticResource PrimaryBlue}"
                            Height="45"
                            Click="Register_Click"
                            IsDefault="True"/>

                    <Button Content="返回登录"
                            Style="{StaticResource MordenBtnStyle}"
                            Background="#3A3A4F"
                            Height="40"
                            Margin="0,10,0,0"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
