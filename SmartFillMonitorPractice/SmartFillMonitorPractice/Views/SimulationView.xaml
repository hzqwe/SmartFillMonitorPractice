<UserControl x:Class="SmartFillMonitorPractice.Views.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:UserControls="clr-namespace:SmartFillMonitorPractice.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="仿真联调状态" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding PlcConnectionText}" Foreground="{StaticResource AppTextMain}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RunStateText}" Foreground="{StaticResource AppAccentColor}" FontSize="14" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding SyncStatusText}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>

                    <UserControls:StatusLight Grid.Column="1"
                                              State="{Binding IndicatorState}"
                                              Width="36"
                                              Height="110"
                                              Margin="16,0,0,0"
                                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="当前批次" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CurrentBatchNo}" Foreground="{StaticResource AppAccentColor}" FontSize="24" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Text="{Binding CurrentPhaseText}" Foreground="{StaticResource AppSuccess}" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding CurrentScriptIndex,StringFormat=采样点位：{0}}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="温度 / 液位" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CurrentTemp,StringFormat={}{0:F1} ℃}" Foreground="{StaticResource AppAccentColor}" FontSize="28" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Text="{Binding SettingTemp,StringFormat=设定：{0:F1} ℃}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding LiquidLevel,StringFormat=液位：{0:F1}%}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="产量 / 节拍" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ActualCount,StringFormat={}{0:N0} PCS}" Foreground="{StaticResource AppAccentColor}" FontSize="28" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Text="{Binding TargetCount,StringFormat=目标：{0:N0} PCS}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding RunningTime,StringFormat=运行：{0:F2} min}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding CurrentCycleTime,StringFormat=当前节拍：{0:F2}s}" Foreground="{StaticResource AppTextMuted}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="实时温度采样柱状图" Foreground="{StaticResource AppTextMain}" FontSize="14" Margin="0,0,0,15"/>
                    <Border Grid.Row="1" Background="#111111" BorderBrush="#333333" BorderThickness="1" MinHeight="220">
                        <lvc:CartesianChart Series="{Binding TempCharts}"
                                            LegendLocation="Top"
                                            Background="Transparent"
                                            Foreground="{StaticResource AppTextMain}"
                                            DisableAnimations="False"
                                            Margin="8">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis ShowLabels="False" Foreground="{StaticResource AppTextMuted}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator IsEnabled="False" Stroke="{StaticResource AppTextMuted}"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="0" MaxValue="120" ShowLabels="True" Foreground="{StaticResource AppTextMain}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{StaticResource AppTextMuted}" StrokeThickness="0.5"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="产量采样柱状图" Foreground="{StaticResource AppTextMain}" FontSize="14" Margin="0,0,0,12"/>
                    <Border Grid.Row="1" Background="#111111" BorderBrush="#333333" BorderThickness="1">
                        <lvc:CartesianChart Series="{Binding CountCharts}"
                                            LegendLocation="None"
                                            Background="Transparent"
                                            Foreground="{StaticResource AppTextMain}"
                                            DisableAnimations="False"
                                            Margin="8,8,8,6">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis ShowLabels="False" Foreground="{StaticResource AppTextMuted}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator IsEnabled="False" Stroke="{StaticResource AppTextMuted}"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="0"
                                          MaxValue="{Binding CountAxisMax}"
                                          ShowLabels="True"
                                          LabelFormatter="{Binding CountAxisFormatter}"
                                          Foreground="{StaticResource AppTextMain}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{StaticResource AppTextMuted}" StrokeThickness="0.5" Step="1"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Border>
                    <TextBlock Grid.Row="2"
                               Text="{Binding ActualCount,StringFormat=当前产量采样值：{0}}"
                               Foreground="{StaticResource AppTextMuted}"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="联调说明" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="该页优先使用真实 Modbus 采样值驱动显示；即使当前值不变，也会持续追加同高度柱子。"
                               Foreground="{StaticResource AppTextMain}"
                               TextWrapping="Wrap"
                               FontSize="13"/>
                    <TextBlock Text="{Binding ValveStatusText,StringFormat=阀门状态：{0}}" Foreground="{StaticResource AppTextMuted}" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SyncStatusText,StringFormat=采样状态：{0}}" Foreground="{StaticResource AppTextMuted}" Margin="0,4,0,0"/>
                    <TextBlock Text="启动/停止/复位只改变页面运行状态，不会把“未读通 Modbus”伪装成已连接。"
                               Foreground="{StaticResource AppTextMuted}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="启动生产" Command="{Binding StartSimulationCommand}" Width="120" Margin="0,0,10,0" Style="{StaticResource AppButtonStyle}"/>
            <Button Content="停止" Command="{Binding StopSimulationCommand}" Width="120" Margin="0,0,10,0" Background="{StaticResource AppWarning}" Style="{StaticResource AppButtonStyle}"/>
            <Button Content="复位" Command="{Binding ResetSimulationCommand}" Width="120" Style="{StaticResource OutLineButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
